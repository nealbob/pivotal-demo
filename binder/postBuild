#!/bin/bash
set -e

# Install pivotal core first, then the JupyterLab extension separately so pip
# can resolve the dependency on the already-installed pivotal package.
COMMIT=42ed75b0395af6725f608d1c47ac9604322f90fd
pip install "pivotal @ git+https://github.com/nealbob/pivotal-py.git@${COMMIT}"
pip install "git+https://github.com/nealbob/pivotal-py.git@${COMMIT}#subdirectory=editors/jupyterlab"

# Disable JupyterLab simple mode (single-document) by default.
# Write directly to user settings — more reliable than overrides.json
# as it doesn't depend on the plugin ID being resolved at build time.
mkdir -p "/home/jovyan/.jupyter/lab/user-settings/@jupyterlab/application-extension/"
cat > "/home/jovyan/.jupyter/lab/user-settings/@jupyterlab/application-extension/shell.jupyterlab-settings" << 'EOF'
{
    "mode": "multiple-document"
}
EOF

# Also write overrides.json as a fallback
mkdir -p "${NB_PYTHON_PREFIX}/share/jupyter/lab/settings"
cp "${REPO_DIR}/binder/overrides.json" "${NB_PYTHON_PREFIX}/share/jupyter/lab/settings/overrides.json"
